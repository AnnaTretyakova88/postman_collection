					"item": [
						{
							"name": "Find Pets by Status",
							"event": [
								{
									"listen": "test",
									"script": {
										"id": "e4b8b849-d7c2-4ae5-b24d-41f245b22f20",
										"exec": [
											"pm.test(\"GET by Status: Pets found by status with code 200`\", function () {\r",
											"    pm.response.to.have.status(200);\r",
											"});\r",
											"pm.test(\"GET by Status: Required headers present\", function () {\r",
											"    pm.response.to.have.header(\"Content-Type\", \"application/json\");\r",
											"});\r",
											"pm.test(\"GET by Status: Pets array is not empty\", () => {\r",
											"    const json = pm.response.json();\r",
											"    pm.expect(json.length).to.be.above(0);\r",
											"    console.log(json.length)\r",
											"});\r",
											"//Visualization table\r",
											"var template = `\r",
											"<style>\r",
											"  body { font-family: Arial, sans-serif; padding: 10px; }\r",
											"  table { border-collapse: collapse; width: 100%; }\r",
											"  th { background-color: #4CAF50; color: white; padding: 8px 12px; text-align: left; }\r",
											"  td { border: 1px solid #ddd; padding: 8px 12px; }\r",
											"  tr:nth-child(even) { background-color: #f2f2f2; }\r",
											"  tr:hover { background-color: #ddd; }\r",
											"</style>\r",
											"<table>\r",
											"  <thead>\r",
											"    <tr>\r",
											"      <th>ID</th>\r",
											"      <th>Name</th>\r",
											"      <th>Category</th>\r",
											"      <th>Tags</th>\r",
											"      <th>Photo URLs</th>\r",
											"      <th>Status</th>\r",
											"    </tr>\r",
											"  </thead>\r",
											"  <tbody>\r",
											"    {{#each pets}}\r",
											"    <tr>\r",
											"      <td>{{id}}</td>\r",
											"      <td>{{name}}</td>\r",
											"      <td>{{category}}</td>\r",
											"      <td>{{tags}}</td>\r",
											"      <td>{{photoUrls}}</td>\r",
											"      <td>{{status}}</td>\r",
											"    </tr>\r",
											"    {{/each}}\r",
											"  </tbody>\r",
											"</table>\r",
											"`;\r",
											"\r",
											"function constructVisualizerPayload() {\r",
											"    var json = pm.response.json();\r",
											"    var pets = json.map(function(pet) {\r",
											"        return {\r",
											"            id: pet.id,\r",
											"            name: pet.name,\r",
											"            category: pet.category ? pet.category.name : '',\r",
											"            tags: pet.tags ? pet.tags.map(function(t) { return t.name; }).join(', ') : '',\r",
											"            photoUrls: pet.photoUrls ? pet.photoUrls.join(', ') : '',\r",
											"            status: pet.status\r",
											"        };\r",
											"    });\r",
											"    return { pets: pets };\r",
											"}\r",
											"\r",
											"pm.visualizer.set(template, constructVisualizerPayload());\r",
											"\r",
											"\r",
											"/*\r",
											"console.log(\"Status Code: \" + pm.response.code + pm.response.status);\r",
											"console.log(\"Pets was searched by status \" + pm.collectionVariables.get(\"petStatus\"));\r",
											"*/"
										],
