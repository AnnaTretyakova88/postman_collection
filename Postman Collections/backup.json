					"item": [
						{
							"name": "Find Pet by ID",
							"event": [
								{
									"listen": "test",
									"script": {
										"id": "eafe5742-b5f4-4e01-adc6-613e13703d54",
										"exec": [
											"pm.test(\"GET by ID: Pet is retrieved with status 200\", function () {\r",
											"    pm.response.to.have.status(200);\r",
											"});\r",
											"pm.test(\"GET by ID: Image ulr presents in body response\", function () {\r",
											"    console.log(pm.response.text())\r",
											"    pm.expect(pm.response.text()).to.include(\"http://placeimg.com/640/480/cats\");\r",
											"});\r",
											"var template = `\r",
											"<style>\r",
											"  body {\r",
											"    font-family: 'Segoe UI', Arial, sans-serif;\r",
											"    background: #f4f6fb;\r",
											"    margin: 0;\r",
											"    padding: 20px;\r",
											"  }\r",
											"  .card {\r",
											"    background: #ffffff;\r",
											"    border-radius: 12px;\r",
											"    box-shadow: 0 4px 16px rgba(0,0,0,0.10);\r",
											"    max-width: 520px;\r",
											"    margin: 0 auto;\r",
											"    overflow: hidden;\r",
											"  }\r",
											"  .card-header {\r",
											"    background: linear-gradient(135deg, #ff6b35, #f7931e);\r",
											"    color: #fff;\r",
											"    padding: 20px 28px 14px 28px;\r",
											"  }\r",
											"  .card-header h2 {\r",
											"    margin: 0 0 4px 0;\r",
											"    font-size: 1.5em;\r",
											"    letter-spacing: 0.5px;\r",
											"  }\r",
											"  .card-header .pet-id {\r",
											"    font-size: 0.85em;\r",
											"    opacity: 0.85;\r",
											"  }\r",
											"  .card-body {\r",
											"    padding: 20px 28px;\r",
											"  }\r",
											"  table {\r",
											"    width: 100%;\r",
											"    border-collapse: collapse;\r",
											"  }\r",
											"  tr {\r",
											"    border-bottom: 1px solid #f0f0f0;\r",
											"  }\r",
											"  tr:last-child {\r",
											"    border-bottom: none;\r",
											"  }\r",
											"  td {\r",
											"    padding: 10px 6px;\r",
											"    vertical-align: top;\r",
											"  }\r",
											"  td.label {\r",
											"    color: #888;\r",
											"    font-size: 0.82em;\r",
											"    font-weight: 600;\r",
											"    text-transform: uppercase;\r",
											"    letter-spacing: 0.6px;\r",
											"    width: 110px;\r",
											"    padding-right: 14px;\r",
											"  }\r",
											"  td.value {\r",
											"    color: #222;\r",
											"    font-size: 0.97em;\r",
											"  }\r",
											"  .badge {\r",
											"    display: inline-block;\r",
											"    padding: 3px 12px;\r",
											"    border-radius: 20px;\r",
											"    font-size: 0.82em;\r",
											"    font-weight: 600;\r",
											"    background: #fff3e0;\r",
											"    color: #e65100;\r",
											"    border: 1px solid #ffcc80;\r",
											"  }\r",
											"  .tag-badge {\r",
											"    display: inline-block;\r",
											"    padding: 2px 10px;\r",
											"    border-radius: 12px;\r",
											"    font-size: 0.80em;\r",
											"    background: #e8f5e9;\r",
											"    color: #2e7d32;\r",
											"    border: 1px solid #a5d6a7;\r",
											"    margin-right: 4px;\r",
											"  }\r",
											"  .photo-link {\r",
											"    color: #1976d2;\r",
											"    text-decoration: none;\r",
											"    font-size: 0.88em;\r",
											"    word-break: break-all;\r",
											"  }\r",
											"  .photo-link:hover {\r",
											"    text-decoration: underline;\r",
											"  }\r",
											"</style>\r",
											"\r",
											"<div class=\"card\">\r",
											"  <div class=\"card-header\">\r",
											"    <h2>{{pet.name}}</h2>\r",
											"    <div class=\"pet-id\">Pet ID: {{pet.id}}</div>\r",
											"  </div>\r",
											"  <div class=\"card-body\">\r",
											"    <table>\r",
											"      <tr>\r",
											"        <td class=\"label\">ID</td>\r",
											"        <td class=\"value\">{{pet.id}}</td>\r",
											"      </tr>\r",
											"      <tr>\r",
											"        <td class=\"label\">Name</td>\r",
											"        <td class=\"value\">{{pet.name}}</td>\r",
											"      </tr>\r",
											"      <tr>\r",
											"        <td class=\"label\">Category</td>\r",
											"        <td class=\"value\">\r",
											"          {{#with pet.category}}\r",
											"            {{name}} <span style=\"color:#aaa;font-size:0.85em;\">(ID: {{id}})</span>\r",
											"          {{/with}}\r",
											"        </td>\r",
											"      </tr>\r",
											"      <tr>\r",
											"        <td class=\"label\">Status</td>\r",
											"        <td class=\"value\"><span class=\"badge\">{{pet.status}}</span></td>\r",
											"      </tr>\r",
											"      <tr>\r",
											"        <td class=\"label\">Tags</td>\r",
											"        <td class=\"value\">\r",
											"          {{#each pet.tags}}\r",
											"            <span class=\"tag-badge\">{{name}}</span>\r",
											"          {{/each}}\r",
											"        </td>\r",
											"      </tr>\r",
											"      <tr>\r",
											"        <td class=\"label\">Photo URLs</td>\r",
											"        <td class=\"value\">\r",
											"          {{#each pet.photoUrls}}\r",
											"            <a class=\"photo-link\" href=\"{{this}}\" target=\"_blank\">{{this}}</a><br>\r",
											"          {{/each}}\r",
											"        </td>\r",
											"      </tr>\r",
											"    </table>\r",
											"  </div>\r",
											"</div>\r",
											"`;\r",
											"\r",
											"function constructVisualizerPayload() {\r",
											"    return { pet: pm.response.json() };\r",
											"}\r",
											"\r",
											"pm.visualizer.set(template, constructVisualizerPayload());\r",
											"\r",
											"/*console.log(\"Status Code: \" + pm.response.code + pm.response.status);\r",
											"console.log(\"Pet with ID \" + pm.environment.get(\"petId\") + \" is found!\");\r",
											"let resp = pm.response.json();\r",
											"console.log(\"His name is \" + resp.name);\r",
											"*/"
