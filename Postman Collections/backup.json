	"item": [
		{
			"name": "Pet Store Controller",
			"item": [
				{
					"name": "Add New Pet",
					"item": [
						{
							"name": "Add New Pet",
							"event": [
								{
									"listen": "prerequest",
									"script": {
										"id": "0bd84ca8-9809-4b10-9392-988b7eb90138",
										"exec": [
											"let id = pm.variables.replaceIn('{{$randomInt}}');\r",
											"pm.environment.set(\"petId\", id);\r",
											"\r",
											"let petName = pm.variables.replaceIn(\"{{$randomFirstName}}\");\r",
											"pm.collectionVariables.set(\"petName\", petName);\r",
											"\r",
											"//let imageUrl = pm.variables.replaceIn(\"{{$randomImageUrl}}\");\r",
											"//pm.variables.set(\"imageUrl\", imageUrl);\r",
											"\r",
											"let statusArr = [\"available\", \"sold\", \"pending\", \"ordered\", \"returned\"];\r",
											"let randomIndex = pm.variables.replaceIn('{{$randomInt}}') % statusArr.length;\r",
											"currentPetStatus = statusArr[randomIndex];\r",
											"pm.collectionVariables.set(\"petStatus\", currentPetStatus);"
										],
										"type": "text/javascript",
										"packages": {},
										"requests": {}
									}
								},
								{
									"listen": "test",
									"script": {
										"id": "4ebce258-f6cc-4eed-83bf-51244ee411b7",
										"exec": [
											"//tests\r",
											"pm.test(\"CREATE: Pet successfully created!\", function () {\r",
											"    pm.expect(pm.response.code).to.be.oneOf([200, 201, 203, 204]);\r",
											"});\r",
											"pm.test(\"CREATE: Pet name is correct\", function () {\r",
											"    petName = pm.collectionVariables.get(\"petName\")\r",
											"    pm.expect(pm.response.text()).to.include(petName);\r",
											"});\r",
											"pm.test(\"CREATE: Pet ID is correct\", function () {\r",
											"    var jsonData = pm.response.json();\r",
											"    expPetId = pm.environment.get(\"petId\");\r",
											"    actPetId = (jsonData.id).toString();\r",
											"    pm.expect(actPetId).to.eql(expPetId);\r",
											"});\r",
											"\r",
											"/*\r",
											"console.log(\"Status Code: \" + pm.response.code + pm.response.status);\r",
											"console.log(\"Global var: \" + pm.globals.get(\"baseUrl\"));\r",
											"console.log(\"Environment var: \" + pm.environment.get(\"petId\"));\r",
											"console.log(\"Collection var: \" + pm.collectionVariables.get(\"petStatus\"))\r",
											"console.log(\"Request var^1: \" + pm.variables.get(\"petName\"));\r",
											"console.log(\"Request var^2: \" + pm.variables.get(\"imageUrl\"));\r",
											"*/\r",
											"// Visualization - Chart\r",
											"var response = pm.response.json();\r",
											"\r",
											"var template = `\r",
											"<canvas id=\"petChart\" height=\"100\"></canvas>\r",
											"<script src=\"https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.5.0/Chart.min.js\"></script>\r",
											"<script>\r",
											"    var ctx = document.getElementById(\"petChart\");\r",
											"    var myChart = new Chart(ctx, {\r",
											"        type: \"bar\",\r",
											"        data: {\r",
											"            labels: [],\r",
											"            datasets: [{\r",
											"                label: \"Pet Info\",\r",
											"                backgroundColor: [\"#4e73df\", \"#1cc88a\", \"#36b9cc\", \"#f6c23e\"],\r",
											"                data: []\r",
											"            }]\r",
											"        },\r",
											"        options: {\r",
											"            legend: { display: false },\r",
											"            title: {\r",
											"                display: true,\r",
											"                text: \"Pet Details\"\r",
											"            },\r",
											"            scales: {\r",
											"                yAxes: [{\r",
											"                    ticks: { beginAtZero: true }\r",
											"                }]\r",
											"            }\r",
											"        }\r",
											"    });\r",
											"\r",
											"    pm.getData(function (err, value) {\r",
											"        myChart.data.labels = value.labels;\r",
											"        myChart.data.datasets[0].data = value.values;\r",
											"        myChart.update();\r",
											"    });\r",
											"</script>`;\r",
											"\r",
											"function constructVisualizerPayload() {\r",
											"    var data = pm.response.json();\r",
											"    return {\r",
											"        labels: [\"Pet ID\", \"Category ID\", \"No. of Tags\", \"No. of Photos\"],\r",
											"        values: [data.id, data.category.id, data.tags.length, data.photoUrls.length]\r",
											"    };\r",
											"}\r",
											"\r",
											"pm.visualizer.set(template, constructVisualizerPayload());"
										],
										"type": "text/javascript",
										"packages": {},
										"requests": {}
									}
								}
							],
							"id": "7a81abb9-63b3-47e7-8c22-cc8a25fcf281",
							"protocolProfileBehavior": {
								"disableBodyPruning": true
							},
