								{
									"listen": "prerequest",
									"script": {
										"id": "3f731d99-9e6c-42d0-be4b-887a3520a783",
										"exec": [
											"let prereqPetId = pm.variables.replaceIn('{{$randomInt}}');\r",
											"let prereqPetName = pm.variables.replaceIn('{{$randomFullName}}');\r",
											"const createNewPet = {\r",
											"    url: pm.globals.get(\"baseUrl\") + \"/pet\",\r",
											"    method: \"POST\",\r",
											"    header: {\r",
											"        \"Content-Type\":\"application/json\"\r",
											"    },\r",
											"    body: JSON.stringify({\r",
											"        \"id\": prereqPetId,\r",
											"        \"category\": {\r",
											"            \"id\": 1000,\r",
											"            \"name\": \"hippo\"\r",
											"            },\r",
											"        \"name\": prereqPetName,\r",
											"        \"photoUrls\": [\r",
											"            \"http://placeimg.com/640/480/cats\"\r",
											"            ],\r",
											"        \"tags\": [\r",
											"            {\"id\": 10, \"name\": \"new\"}\r",
											"            ],\r",
											"        \"status\": \"pending\"\r",
											"    })\r",
											"}\r",
											"\r",
											"pm.sendRequest(createNewPet, function(error, response){\r",
											"    pm.test(\"Pre-request Create Pet successed\", function(){\r",
											"        pm.expect(response.code).to.eql(200)\r",
											"    })\r",
											"\r",
											"    const respData = response.json();\r",
											"    pm.environment.set(\"petId\", respData.id);\r",
											"    console.log(\"Pet with ID \" + respData.id + \" is created\")\r",
											"\r",
											"})"
										],
										"type": "text/javascript",
										"packages": {},
										"requests": {}
									}
								}
