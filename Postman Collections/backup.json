											"        id: { type: \"number\" },\r",
											"        name: { type: \"string\" }\r",
											"      }\r",
											"    },\r",
											"    name: {\r",
											"        type: \"string\"\r",
											"        },\r",
											"    photoUrls: {\r",
											"        type: \"array\"\r",
											"    },\r",
											"    tags: {\r",
											"        type: \"array\",\r",
											"        properties: {\r",
											"        id: { type: \"number\" },\r",
											"        name: { type: \"string\" }\r",
											"      }\r",
											"    },\r",
											"    status: {\r",
											"        type: \"string\"\r",
											"    }\r",
											"  }\r",
											"};\r",
											"pm.test('PUT response has correct body structure', () => {\r",
											"  pm.response.to.have.jsonSchema(schema);\r",
											"});\r",
											"\r",
											"/*console.log(\"Status Code: \" + pm.response.code + pm.response.status);\r",
