											"});\r",
											"pm.test(\"DELETE Pet: Body is correct\", function () {\r",
											"    const json = pm.response.json();\r",
											"    pm.expect(json.code).to.eql(200);\r",
											"    pm.expect(json.type).to.eql(\"unknown\");\r",
											"});\r",
											"const getPetByStatus = {\r",
											"    url: pm.globals.get(\"baseUrl\") + \"/pet/findByStatus?status=\" + pm.collectionVariables.get(\"deletedPetStatus\"),\r",
											"    method: \"GET\",\r",
											"    header: {\r",
											"        \"Content-Type\":\"application/json\"\r",
											"    } \r",
											"}\r",
											"pm.sendRequest(getPetByStatus, function(error, response){\r",
											"    pm.test(\"Post-request: Get Pet by status of deleted pet\", function(){\r",
											"        pm.expect(response.code).to.eql(200)\r",
											"    })\r",
											"    pm.test(\"Post-request: Deleted pet not found in the array\", function(){\r",
											"        const respData = response.json();\r",
											"        console.log(respData);\r",
											"        const deletedPetId = pm.environment.get(\"petId\")\r",
											"        const foundPet = respData.find(pet => pet.id === deletedPetId);\r",
											"        pm.expect(foundPet).to.be.undefined;\r",
											"    })    \r",
											"})\r",
											"/*console.log(\"Status Code: \" + pm.response.code + pm.response.status);\r",
											"pm.collectionVariables.clear();\r",
											"pm.environment.clear();\r",
											"*/"
										],
