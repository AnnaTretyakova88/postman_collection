					"item": [
						{
							"name": "Update Pet with Form Data",
							"event": [
								{
									"listen": "prerequest",
									"script": {
										"id": "66394911-b1a2-464f-8cf8-9e6835bebd8f",
										"exec": [
											"let statusArr = [\"available\", \"sold\", \"pending\", \"returned\"];\r",
											"let randomIndex = pm.variables.replaceIn('{{$randomInt}}') % statusArr.length;\r",
											"newPetStatus = statusArr[randomIndex];\r",
											"console.log(newPetStatus);\r",
											"\r",
											"const getPetByStatus = {\r",
											"    url: pm.globals.get(\"baseUrl\") + \"/pet/findByStatus?status=\" + newPetStatus,\r",
											"    method: \"GET\",\r",
											"    header: {\r",
											"        \"Content-Type\":\"application/json\"\r",
											"    }\r",
											"}\r",
											"pm.sendRequest(getPetByStatus, function(error, response){\r",
											"    pm.test(\"Pre-request GET by Status successed\", function(){\r",
											"        pm.expect(response.code).to.eql(200)\r",
											"    })\r",
											"    const respData = response.json();\r",
											"    orderedPetId = respData[0].id;\r",
											"    pm.environment.set(\"orderedPetId\", orderedPetId);\r",
											"})"
										],
										"type": "text/javascript",
										"packages": {},
										"requests": {}
									}
								},
								{
									"listen": "test",
									"script": {
										"id": "f817ae16-b5b5-4001-970f-056f97cfc164",
										"exec": [
											"pm.test(\"UPDATE Pet: Successful POST request\", function () {\r",
											"    pm.expect(pm.response.code).to.not.be.oneOf([400, 401, 403, 405, 500, 501, 502, 503]);\r",
											"});\r",
											"\r",
											"pm.test('UPDATE Pet: All pets have got \"Unknown\" type property', function() {\r",
											"    const bodyJS = pm.response.json();\r",
											"    pm.expect(bodyJS).to.have.property('type', 'unknown');\r",
											"});\r",
											"\r",
											"const getPetById = {\r",
											"    url: pm.globals.get(\"baseUrl\") + \"/pet/\" + pm.environment.get(\"orderedPetId\"),\r",
											"    method: \"GET\",\r",
											"    header: {\r",
											"        \"Content-Type\":\"application/json\"\r",
											"    }\r",
											"}\r",
											"\r",
											"setTimeout(()=>{\r",
											"    pm.sendRequest(getPetById, function(error, response){\r",
											"    pm.test(\"Post-request GET by ID successed\", function(){\r",
											"        pm.expect(response.code).to.eql(200)\r",
											"    })\r",
											"    pm.test(\"Pet gets status Ordered\", function(){\r",
											"        const respData = response.json();\r",
											"        pm.expect(respData.status).to.eql(\"ordered\");\r",
											"        console.log(\"Pet with ID \" + respData.id + \" updated with status \" + respData.status)\r",
											"    })\r",
											"})\r",
											"}, 3000)\r",
											"/*\r",
											"console.log(\"Status Code: \" + pm.response.code + pm.response.status);\r",
											"console.log(\"Pet \" + pm.environment.get(\"petId\") + \" gets new status \" + pm.collectionVariables.get(\"newPetStatus\"));\r",
											"*/"
										],
										"type": "text/javascript",
										"packages": {},
										"requests": {}
									}
								}
